// Marketplace + Billing + Subscriptions + Payments
// ══════════════════════════════════════════════════════════════════════

// ── Plan Tier ─────────────────────────────────────────────────────────

enum PlanTier {
  FREE
  BASIC       // $99/mo
  PROFESSIONAL // $299/mo
  ENTERPRISE  // $799/mo
  CUSTOM
}

enum PlanInterval {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  PAUSED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  DISPUTED
  CANCELED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

enum MarketplaceListingType {
  TERRITORY      // ZIP/city territory for sale
  LEAD_PACKAGE   // Bundle of leads for one-time purchase
  LEAD_CREDIT    // Single lead credit
}

enum MarketplaceListingStatus {
  ACTIVE
  SOLD
  EXPIRED
  REMOVED
}

// ── Plans ──────────────────────────────────────────────────────────────

model Plan {
  id              String       @id @default(uuid())
  name            String       // "Professional"
  tier            PlanTier     @unique
  slug            String       @unique  // "professional"

  // Pricing
  monthlyPrice    Decimal      @db.Decimal(10,2) @map("monthly_price")
  annualPrice     Decimal?     @db.Decimal(10,2) @map("annual_price")  // discounted

  // Stripe IDs (created via Stripe dashboard or API)
  stripeMonthlyPriceId String?  @map("stripe_monthly_price_id")
  stripeAnnualPriceId  String?  @map("stripe_annual_price_id")

  // Feature limits (null = unlimited)
  maxTerritories   Int?        @map("max_territories")   // max owned territories
  maxLeadsPerMonth Int?        @map("max_leads_per_month")
  maxUsers         Int?        @map("max_users")          // team seats
  maxSeoPages      Int?        @map("max_seo_pages")

  // Feature flags (JSON for flexibility)
  features         Json        @default("{}") // { aiContent, callCenter, analytics, apiAccess, ... }

  // Display
  description      String?
  badge            String?     // "Most Popular"
  color            String      @default("#1B3A5C")
  isActive         Boolean     @default(true) @map("is_active")
  sortOrder        Int         @default(0)    @map("sort_order")

  subscriptions    Subscription[]

  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt      @map("updated_at")

  @@map("plans")
}

// ── Subscriptions ──────────────────────────────────────────────────────

model Subscription {
  id               String             @id @default(uuid())
  userId           String             @map("user_id")
  user             User               @relation("UserSubscriptions", fields: [userId], references: [id])
  planId           String             @map("plan_id")
  plan             Plan               @relation(fields: [planId], references: [id])

  // Stripe IDs
  stripeCustomerId    String           @map("stripe_customer_id")
  stripeSubId         String?  @unique @map("stripe_sub_id")         // Stripe Subscription ID
  stripePriceId       String?          @map("stripe_price_id")

  // Status
  status           SubscriptionStatus @default(TRIALING)
  interval         PlanInterval       @default(MONTHLY)

  // Dates
  trialEnd         DateTime?          @map("trial_end")
  currentPeriodStart DateTime?        @map("current_period_start")
  currentPeriodEnd   DateTime?        @map("current_period_end")
  canceledAt       DateTime?          @map("canceled_at")
  cancelAtPeriodEnd Boolean           @default(false) @map("cancel_at_period_end")
  endedAt          DateTime?          @map("ended_at")

  // Overrides (for custom/negotiated plans)
  customMonthlyPrice Decimal?         @db.Decimal(10,2) @map("custom_monthly_price")
  notes            String?

  payments         Payment[]
  invoices         Invoice[]
  usageRecords     UsageRecord[]

  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt      @map("updated_at")

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([status])
  @@map("subscriptions")
}

// ── Payments ───────────────────────────────────────────────────────────

model Payment {
  id               String        @id @default(uuid())
  subscriptionId   String?       @map("subscription_id")
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])
  userId           String        @map("user_id")

  // Stripe IDs
  stripePaymentIntentId String?  @unique @map("stripe_payment_intent_id")
  stripeChargeId        String?  @unique @map("stripe_charge_id")
  stripeInvoiceId       String?  @map("stripe_invoice_id")

  // Amount
  amount           Decimal       @db.Decimal(10,2)
  currency         String        @default("usd")
  status           PaymentStatus @default(PENDING)

  // Metadata
  description      String?
  metadata         Json          @default("{}")

  // Refund
  refundedAmount   Decimal?      @db.Decimal(10,2) @map("refunded_amount")
  refundedAt       DateTime?     @map("refunded_at")
  refundReason     String?       @map("refund_reason")

  invoice          Invoice?

  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt      @map("updated_at")

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@map("payments")
}

// ── Invoices ───────────────────────────────────────────────────────────

model Invoice {
  id               String        @id @default(uuid())
  subscriptionId   String?       @map("subscription_id")
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])
  paymentId        String?       @unique @map("payment_id")
  payment          Payment?      @relation(fields: [paymentId], references: [id])
  userId           String        @map("user_id")

  // Stripe
  stripeInvoiceId  String?       @unique @map("stripe_invoice_id")
  invoiceNumber    String        @unique @map("invoice_number")  // INV-2025-0001

  // Amounts
  subtotal         Decimal       @db.Decimal(10,2)
  tax              Decimal       @default(0) @db.Decimal(10,2)
  total            Decimal       @db.Decimal(10,2)
  currency         String        @default("usd")

  // Status
  status           InvoiceStatus @default(OPEN)
  dueDate          DateTime?     @map("due_date")
  paidAt           DateTime?     @map("paid_at")

  // Content
  lineItems        Json          @default("[]")  @map("line_items")
  billingDetails   Json          @default("{}")  @map("billing_details")  // name, address
  invoicePdfUrl    String?       @map("invoice_pdf_url")
  hostedInvoiceUrl String?       @map("hosted_invoice_url")

  // Period
  periodStart      DateTime?     @map("period_start")
  periodEnd        DateTime?     @map("period_end")

  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt      @map("updated_at")

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@map("invoices")
}

// ── Usage Records (for metered billing) ───────────────────────────────

model UsageRecord {
  id             String       @id @default(uuid())
  subscriptionId String       @map("subscription_id")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  userId         String       @map("user_id")

  metric         String       // "leads_assigned", "seo_pages", "territories"
  quantity       Int
  periodStart    DateTime     @map("period_start")
  periodEnd      DateTime     @map("period_end")

  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([subscriptionId, metric])
  @@map("usage_records")
}

// ── Marketplace Listings ───────────────────────────────────────────────

model MarketplaceListing {
  id             String                   @id @default(uuid())
  type           MarketplaceListingType
  status         MarketplaceListingStatus @default(ACTIVE)
  sellerId       String?                  @map("seller_id")    // null = platform

  // What's being sold
  territoryId    String?                  @map("territory_id")  // if TERRITORY
  title          String
  description    String?
  highlights     Json    @default("[]")   // ["Exclusive ZIP", "10 leads/mo estimated"]

  // Pricing
  price          Decimal  @db.Decimal(10,2)
  isRecurring    Boolean  @default(false)  @map("is_recurring")  // monthly subscription
  recurringPrice Decimal? @db.Decimal(10,2) @map("recurring_price")

  // Stats & display
  leadsPerMonth  Int?     @map("leads_per_month")
  medianValue    String?  @map("median_value")     // "$480K"
  stateCode      String   @map("state_code")
  zipCode        String?  @map("zip_code")
  city           String?
  priority       Int      @default(0)

  // Sold
  buyerId        String?  @map("buyer_id")
  soldAt         DateTime? @map("sold_at")
  stripeSessionId String?  @map("stripe_session_id")

  purchases      MarketplacePurchase[]

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt      @map("updated_at")

  @@index([type, status])
  @@index([stateCode, status])
  @@index([price])
  @@map("marketplace_listings")
}

// ── Marketplace Purchases ──────────────────────────────────────────────

model MarketplacePurchase {
  id             String              @id @default(uuid())
  listingId      String              @map("listing_id")
  listing        MarketplaceListing  @relation(fields: [listingId], references: [id])
  buyerId        String              @map("buyer_id")
  amount         Decimal             @db.Decimal(10,2)
  currency       String              @default("usd")

  // Stripe
  stripeSessionId      String?  @unique @map("stripe_session_id")
  stripePaymentIntentId String? @unique @map("stripe_payment_intent_id")
  stripeSubscriptionId  String?          @map("stripe_subscription_id")

  status         PaymentStatus       @default(PENDING)
  completedAt    DateTime?           @map("completed_at")
  metadata       Json                @default("{}")

  createdAt      DateTime            @default(now()) @map("created_at")

  @@index([buyerId])
  @@map("marketplace_purchases")
}

// ── Stripe Webhook Events (idempotency log) ────────────────────────────

model StripeWebhookEvent {
  id           String   @id @default(uuid())
  stripeEventId String  @unique @map("stripe_event_id")
  type         String
  processed    Boolean  @default(false)
  error        String?
  payload      Json
  processedAt  DateTime? @map("processed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([type, processed])
  @@map("stripe_webhook_events")
}
