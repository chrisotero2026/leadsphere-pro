// ── Enums ─────────────────────────────────────────────────────────────

enum AiJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
}

enum AiJobType {
  LEAD_SCORE           // Full AI scoring of a lead
  BATCH_SCORE          // Bulk scoring job
  FOLLOWUP_SEQUENCE    // Generate follow-up messages
  CONVERSATION_INSIGHT // Analyze call transcript
  TERRITORY_PREDICTION // Predict territory performance
  AGENT_COACHING       // Generate coaching recommendations
  CAMPAIGN_ANALYSIS    // Analyze campaign ROI
}

enum FollowUpChannel {
  EMAIL
  SMS
  CALL_REMINDER
  PUSH
}

enum FollowUpStatus {
  PENDING
  SENT
  FAILED
  SKIPPED   // Lead responded before this step
  CANCELED
}

enum InsightType {
  LEAD_OPPORTUNITY   // High-value lead detected
  TERRITORY_TREND    // Territory performance shift
  AGENT_COACHING     // Agent needs coaching
  REVENUE_FORECAST   // Updated revenue prediction
  CAMPAIGN_ALERT     // Campaign underperforming
  CONVERSION_PATTERN // Pattern detected
}

// ── Lead AI Score ─────────────────────────────────────────────────────

model LeadAiScore {
  id              String   @id @default(uuid())
  leadId          String   @unique @map("lead_id")
  lead            Lead     @relation("LeadAiScore", fields: [leadId], references: [id], onDelete: Cascade)

  // Composite score (0–100)
  totalScore      Int      @map("total_score")        // Final weighted score
  temperature     String   @default("COLD")           // HOT/WARM/COLD recalculated

  // Dimension scores (0–100 each)
  urgencyScore    Int      @default(0) @map("urgency_score")
  budgetScore     Int      @default(0) @map("budget_score")
  intentScore     Int      @default(0) @map("intent_score")
  engagementScore Int      @default(0) @map("engagement_score")
  creditScore     Int      @default(0) @map("credit_score")
  timelineScore   Int      @default(0) @map("timeline_score")

  // AI analysis output
  summary         String?  @db.Text           // "High-urgency seller in prime VA market..."
  strengths       Json     @default("[]")     // ["IMMEDIATE urgency", "High estimated value"]
  risks           Json     @default("[]")     // ["No phone provided", "Unknown credit"]
  recommendations Json     @default("[]")    // ["Call within 2 hours", "Offer cash program"]
  callScript      String?  @db.Text @map("call_script")   // Suggested opening script
  objectionHandlers Json   @default("{}") @map("objection_handlers") // Map of objection → response
  productMatch    String?  @map("product_match")  // "CASH_OFFER" | "TRADITIONAL_LISTING"
  programMatch    String?  @map("program_match")  // "FHA_ASSISTANCE" | "INVESTOR_NETWORK"

  // Prediction
  closeProbability  Decimal?  @db.Decimal(5,4) @map("close_probability")  // 0.0–1.0
  estimatedDaysToClose Int?   @map("estimated_days_to_close")
  estimatedRevenue    Decimal? @db.Decimal(10,2) @map("estimated_revenue")

  // Metadata
  modelVersion    String   @default("gpt-4o") @map("model_version")
  tokensUsed      Int?     @map("tokens_used")
  processingMs    Int?     @map("processing_ms")
  lastScored      DateTime @default(now()) @map("last_scored")
  scoreVersion    Int      @default(1) @map("score_version")  // increments on re-score

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt      @map("updated_at")

  @@index([totalScore])
  @@index([temperature])
  @@index([closeProbability])
  @@map("lead_ai_scores")
}

// ── Score History (one record per scoring event) ──────────────────────

model LeadScoreHistory {
  id            String   @id @default(uuid())
  leadId        String   @map("lead_id")
  lead          Lead     @relation("LeadScoreHistory", fields: [leadId], references: [id], onDelete: Cascade)
  totalScore    Int      @map("total_score")
  temperature   String
  trigger       String   // "created", "updated", "manual", "scheduled"
  delta         Int?     // score change from previous
  snapshot      Json     @default("{}") // lead data at time of scoring
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([leadId, createdAt])
  @@map("lead_score_history")
}

// ── AI Job Queue ──────────────────────────────────────────────────────

model AiJob {
  id            String      @id @default(uuid())
  type          AiJobType
  status        AiJobStatus @default(QUEUED)
  priority      Int         @default(5)    // 1 = highest, 10 = lowest
  payload       Json        @default("{}")
  result        Json?
  error         String?
  attempts      Int         @default(0)
  maxAttempts   Int         @default(3) @map("max_attempts")
  scheduledFor  DateTime    @default(now()) @map("scheduled_for")
  startedAt     DateTime?   @map("started_at")
  completedAt   DateTime?   @map("completed_at")
  processingMs  Int?        @map("processing_ms")
  tokensUsed    Int?        @map("tokens_used")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([status, scheduledFor])
  @@index([type, status])
  @@index([priority, status, scheduledFor])
  @@map("ai_jobs")
}

// ── Automated Follow-up Sequences ─────────────────────────────────────

model FollowUpSequence {
  id            String   @id @default(uuid())
  leadId        String   @map("lead_id")
  lead          Lead     @relation("FollowUpSequences", fields: [leadId], references: [id], onDelete: Cascade)
  triggeredBy   String   @map("triggered_by")  // "no_response_24h", "assigned", "score_change"
  isActive      Boolean  @default(true) @map("is_active")
  completedAt   DateTime? @map("completed_at")
  canceledAt    DateTime? @map("canceled_at")

  steps         FollowUpStep[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  @@index([leadId, isActive])
  @@map("follow_up_sequences")
}

model FollowUpStep {
  id              String          @id @default(uuid())
  sequenceId      String          @map("sequence_id")
  sequence        FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
  stepNumber      Int             @map("step_number")
  channel         FollowUpChannel
  status          FollowUpStatus  @default(PENDING)
  scheduledFor    DateTime        @map("scheduled_for")
  sentAt          DateTime?       @map("sent_at")
  subject         String?
  body            String?         @db.Text
  aiGenerated     Boolean         @default(true) @map("ai_generated")
  deliveryRef     String?         @map("delivery_ref")  // Twilio SID, email ID, etc.
  openedAt        DateTime?       @map("opened_at")
  repliedAt       DateTime?       @map("replied_at")
  error           String?

  createdAt       DateTime        @default(now()) @map("created_at")

  @@index([status, scheduledFor])
  @@map("follow_up_steps")
}

// ── Predictive Metrics (time-series, one row per period) ──────────────

model PredictiveMetric {
  id               String   @id @default(uuid())
  metricType       String   @map("metric_type")
  // "territory_conversion", "agent_performance", "revenue_forecast",
  // "lead_velocity", "campaign_roi"

  entityType       String?  @map("entity_type")   // "territory" | "agent" | "campaign"
  entityId         String?  @map("entity_id")
  periodStart      DateTime @map("period_start")
  periodEnd        DateTime @map("period_end")

  // Actuals (filled as data comes in)
  actualValue      Decimal? @db.Decimal(12,2) @map("actual_value")

  // Predictions
  predictedValue   Decimal  @db.Decimal(12,2) @map("predicted_value")
  confidenceLow    Decimal? @db.Decimal(12,2) @map("confidence_low")
  confidenceHigh   Decimal? @db.Decimal(12,2) @map("confidence_high")
  confidenceScore  Decimal? @db.Decimal(5,4)  @map("confidence_score")  // 0–1

  // Supporting data
  methodology      String?  @default("statistical") // "statistical" | "ml" | "hybrid"
  inputFeatures    Json     @default("{}")  @map("input_features")
  metadata         Json     @default("{}")

  createdAt        DateTime @default(now()) @map("created_at")

  @@index([metricType, entityId, periodStart])
  @@index([metricType, periodStart])
  @@map("predictive_metrics")
}

// ── AI Insights (alerts + recommendations) ────────────────────────────

model AiInsight {
  id            String      @id @default(uuid())
  type          InsightType
  title         String
  body          String      @db.Text
  severity      String      @default("INFO")  // INFO | WARNING | URGENT | CRITICAL
  entityType    String?     @map("entity_type")
  entityId      String?     @map("entity_id")
  targetUserId  String?     @map("target_user_id")  // specific user or null = all admins
  metadata      Json        @default("{}")
  isRead        Boolean     @default(false) @map("is_read")
  readAt        DateTime?   @map("read_at")
  expiresAt     DateTime?   @map("expires_at")
  actionUrl     String?     @map("action_url")
  actionLabel   String?     @map("action_label")

  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([targetUserId, isRead])
  @@index([type, createdAt])
  @@index([severity, isRead])
  @@map("ai_insights")
}

// ── Territory Analytics Snapshot (materialized for speed) ─────────────

model TerritoryAnalyticsSnapshot {
  id               String   @id @default(uuid())
  territoryId      String   @map("territory_id")
  snapshotDate     DateTime @map("snapshot_date") @db.Date

  // Lead metrics
  totalLeads       Int      @default(0) @map("total_leads")
  assignedLeads    Int      @default(0) @map("assigned_leads")
  convertedLeads   Int      @default(0) @map("converted_leads")
  avgScore         Decimal  @default(0) @db.Decimal(5,2) @map("avg_score")
  hotLeads         Int      @default(0) @map("hot_leads")
  warmLeads        Int      @default(0) @map("warm_leads")

  // Financial
  estimatedRevenue Decimal  @default(0) @db.Decimal(12,2) @map("estimated_revenue")
  actualRevenue    Decimal  @default(0) @db.Decimal(12,2) @map("actual_revenue")
  conversionRate   Decimal  @default(0) @db.Decimal(5,4) @map("conversion_rate")

  // Prediction
  predictedLeads30d Int?    @map("predicted_leads_30d")
  predictedRevenue30d Decimal? @db.Decimal(12,2) @map("predicted_revenue_30d")
  trendDirection   String   @default("STABLE")  // GROWING | STABLE | DECLINING

  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([territoryId, snapshotDate])
  @@index([territoryId, snapshotDate])
  @@map("territory_analytics_snapshots")
}

// ── Agent Performance Metrics ─────────────────────────────────────────

model AgentPerformanceMetric {
  id               String   @id @default(uuid())
  agentId          String   @map("agent_id")
  periodStart      DateTime @map("period_start")
  periodEnd        DateTime @map("period_end")

  // Volume
  leadsAssigned    Int      @default(0) @map("leads_assigned")
  leadsAccepted    Int      @default(0) @map("leads_accepted")
  leadsConverted   Int      @default(0) @map("leads_converted")
  leadsRejected    Int      @default(0) @map("leads_rejected")

  // Speed
  avgResponseHours Decimal? @db.Decimal(6,2) @map("avg_response_hours")
  avgDaysToClose   Decimal? @db.Decimal(6,2) @map("avg_days_to_close")

  // Quality
  avgLeadScore     Decimal? @db.Decimal(5,2) @map("avg_lead_score")
  conversionRate   Decimal? @db.Decimal(5,4) @map("conversion_rate")
  acceptanceRate   Decimal? @db.Decimal(5,4) @map("acceptance_rate")

  // Revenue
  estimatedRevenue Decimal  @default(0) @db.Decimal(12,2) @map("estimated_revenue")

  // AI coaching
  coachingNotes    String?  @db.Text @map("coaching_notes")
  strengthAreas    Json     @default("[]") @map("strength_areas")
  improvementAreas Json     @default("[]") @map("improvement_areas")

  createdAt        DateTime @default(now()) @map("created_at")

  @@unique([agentId, periodStart])
  @@index([agentId, periodStart])
  @@map("agent_performance_metrics")
}