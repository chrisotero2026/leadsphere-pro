// LeadSphere Pro — Schema Unificado (MVP + AI + Billing + Territory + SEO)
generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════ CORE ═══════════════════════

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions Json     @default("{}")
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("roles")
}

model User {
  id          String     @id @default(uuid())
  email       String     @unique
  password    String
  firstName   String     @map("first_name")
  lastName    String     @map("last_name")
  phone       String?
  avatar      String?
  roleId      String     @map("role_id")
  role        Role       @relation(fields: [roleId], references: [id])
  status      UserStatus @default(ACTIVE)
  lastLoginAt DateTime?  @map("last_login_at")
  stripeCustomerId String? @map("stripe_customer_id")
  assignedLeads  LeadAssignment[] @relation("AssignedTo")
  createdLeads   Lead[]           @relation("CreatedBy")
  activities     CrmActivity[]
  territories    Territory[]
  subscriptions  Subscription[]
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  @@index([email])
  @@map("users")
}

enum UserStatus { ACTIVE INACTIVE SUSPENDED }

model Lead {
  id             String        @id @default(uuid())
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  email          String
  phone          String?
  address        String?
  city           String?
  state          String?       @default("VA")
  zipCode        String?       @map("zip_code")
  propertyType   PropertyType? @map("property_type")
  estimatedValue Decimal?      @map("estimated_value") @db.Decimal(12, 2)
  urgency        Urgency?
  score          Int           @default(0)
  temperature    Temperature   @default(COLD)
  status         LeadStatus    @default(NEW)
  source         String?       @default("manual")
  sourceUrl      String?       @map("source_url")
  notes          String?
  createdById    String        @map("created_by_id")
  createdBy      User          @relation("CreatedBy", fields: [createdById], references: [id])
  assignments    LeadAssignment[]
  activities     CrmActivity[]
  tags           LeadTag[]
  aiScores       AiLeadScore[]
  followUpSeqs   FollowUpSequence[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  @@index([email])
  @@index([zipCode])
  @@index([status])
  @@index([score])
  @@map("leads")
}

enum LeadStatus   { NEW CONTACTED QUALIFIED PROPOSAL NEGOTIATION CLOSED_WON CLOSED_LOST }
enum PropertyType { SINGLE_FAMILY MULTI_FAMILY CONDO TOWNHOUSE LAND COMMERCIAL }
enum Urgency      { IMMEDIATE THREE_MONTHS SIX_MONTHS EXPLORING }
enum Temperature  { HOT WARM COLD }

model LeadAssignment {
  id         String   @id @default(uuid())
  leadId     String   @map("lead_id")
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  user       User     @relation("AssignedTo", fields: [userId], references: [id])
  isActive   Boolean  @default(true) @map("is_active")
  assignedAt DateTime @default(now()) @map("assigned_at")
  notes      String?
  @@unique([leadId, userId])
  @@map("lead_assignments")
}

model CrmActivity {
  id          String       @id @default(uuid())
  leadId      String       @map("lead_id")
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String       @map("user_id")
  user        User         @relation(fields: [userId], references: [id])
  type        ActivityType
  subject     String?
  body        String
  outcome     String?
  scheduledAt DateTime?    @map("scheduled_at")
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  @@index([leadId])
  @@map("crm_activities")
}

enum ActivityType { NOTE CALL EMAIL MEETING SMS STATUS_CHANGE }

model Tag {
  id    String    @id @default(uuid())
  name  String    @unique
  color String    @default("#6B7280")
  leads LeadTag[]
  @@map("tags")
}

model LeadTag {
  leadId String @map("lead_id")
  tagId  String @map("tag_id")
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([leadId, tagId])
  @@map("lead_tags")
}

// ═══════════════════════ AI MODULE ══════════════════════

model AiLeadScore {
  id                String    @id @default(uuid())
  leadId            String    @map("lead_id")
  lead              Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  totalScore        Int       @map("total_score")
  temperature       Temperature
  urgencyScore      Int       @default(0) @map("urgency_score")
  budgetScore       Int       @default(0) @map("budget_score")
  intentScore       Int       @default(0) @map("intent_score")
  engagementScore   Int       @default(0) @map("engagement_score")
  creditScore       Int       @default(0) @map("credit_score")
  timelineScore     Int       @default(0) @map("timeline_score")
  summary           String?
  recommendations   Json      @default("[]")
  closeProbability  Decimal?  @map("close_probability") @db.Decimal(5,4)
  estimatedValue    Decimal?  @map("estimated_value") @db.Decimal(12,2)
  scoredAt          DateTime  @default(now()) @map("scored_at")
  modelUsed         String?   @map("model_used")
  processingMs      Int?      @map("processing_ms")
  @@index([leadId])
  @@index([totalScore])
  @@map("ai_lead_scores")
}

model FollowUpSequence {
  id         String   @id @default(uuid())
  leadId     String   @map("lead_id")
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel    String
  status     String   @default("active")
  steps      Json     @default("[]")
  currentStep Int     @default(0) @map("current_step")
  nextRunAt  DateTime? @map("next_run_at")
  completedAt DateTime? @map("completed_at")
  createdAt  DateTime @default(now()) @map("created_at")
  @@index([leadId])
  @@map("follow_up_sequences")
}

model AiInsight {
  id        String   @id @default(uuid())
  type      String
  priority  String   @default("medium")
  title     String
  message   String
  data      Json     @default("{}")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  @@map("ai_insights")
}

// ═════════════════════ BILLING MODULE ════════════════════

model Plan {
  id            String   @id
  name          String
  displayName   String   @map("display_name")
  price         Decimal  @db.Decimal(10,2)
  stripePriceId String?  @map("stripe_price_id")
  features      Json     @default("{}")
  limits        Json     @default("{}")
  isActive      Boolean  @default(true) @map("is_active")
  subscriptions Subscription[]
  @@map("plans")
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  user                 User     @relation(fields: [userId], references: [id])
  planId               String   @map("plan_id")
  plan                 Plan     @relation(fields: [planId], references: [id])
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  status               String   @default("active")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean  @default(false) @map("cancel_at_period_end")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  @@index([userId])
  @@map("subscriptions")
}

model TerritoryListing {
  id          String   @id @default(uuid())
  zipCode     String   @unique @map("zip_code")
  city        String
  state       String
  tier        String
  price       Decimal  @db.Decimal(10,2)
  monthlyPrice Decimal @map("monthly_price") @db.Decimal(10,2)
  isAvailable Boolean  @default(true) @map("is_available")
  ownerId     String?  @map("owner_id")
  createdAt   DateTime @default(now()) @map("created_at")
  @@map("territory_listings")
}

// ════════════════════ TERRITORY MODULE ═══════════════════

model Territory {
  id          String   @id @default(uuid())
  zipCode     String   @map("zip_code")
  city        String
  state       String   @default("VA")
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  isActive    Boolean  @default(true) @map("is_active")
  assignedAt  DateTime @default(now()) @map("assigned_at")
  assignments TerritoryAssignment[]
  notifications TerritoryNotification[]
  @@unique([zipCode, userId])
  @@map("territories")
}

model TerritoryAssignment {
  id          String    @id @default(uuid())
  territoryId String    @map("territory_id")
  territory   Territory @relation(fields: [territoryId], references: [id])
  leadId      String    @map("lead_id")
  assignedAt  DateTime  @default(now()) @map("assigned_at")
  @@map("territory_assignments")
}

model TerritoryNotification {
  id          String    @id @default(uuid())
  territoryId String    @map("territory_id")
  territory   Territory @relation(fields: [territoryId], references: [id])
  type        String
  message     String
  isRead      Boolean   @default(false) @map("is_read")
  createdAt   DateTime  @default(now()) @map("created_at")
  @@map("territory_notifications")
}

// ══════════════════════ SEO MODULE ═══════════════════════

model SeoTemplate {
  id        String     @id @default(uuid())
  name      String
  type      String
  content   Json
  isDefault Boolean    @default(false) @map("is_default")
  pages     SeoPage[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  @@map("seo_templates")
}

model SeoPage {
  id          String      @id @default(uuid())
  slug        String      @unique
  title       String
  metaDesc    String      @map("meta_desc")
  city        String
  state       String
  zipCode     String?     @map("zip_code")
  content     Json
  isPublished Boolean     @default(false) @map("is_published")
  templateId  String?     @map("template_id")
  template    SeoTemplate? @relation(fields: [templateId], references: [id])
  leads       SeoPageLead[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  @@map("seo_pages")
}

model SeoPageLead {
  id        String   @id @default(uuid())
  pageId    String   @map("page_id")
  page      SeoPage  @relation(fields: [pageId], references: [id])
  name      String
  email     String
  phone     String?
  message   String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("seo_page_leads")
}

model SeoJob {
  id        String   @id @default(uuid())
  status    String   @default("pending")
  total     Int      @default(0)
  completed Int      @default(0)
  failed    Int      @default(0)
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("seo_jobs")
}
