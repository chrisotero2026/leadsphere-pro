// LeadSphere Pro — Prisma Schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════ CORE ═══════════════════════

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions Json     @default("{}")
  users       User[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  @@map("roles")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  password         String
  firstName        String     @map("first_name")
  lastName         String     @map("last_name")
  phone            String?
  avatar           String?
  roleId           String     @map("role_id")
  role             Role       @relation(fields: [roleId], references: [id])
  status           UserStatus @default(ACTIVE)
  lastLoginAt      DateTime?  @map("last_login_at")
  stripeCustomerId String?    @map("stripe_customer_id")
  assignedLeads    LeadAssignment[] @relation("AssignedTo")
  createdLeads     Lead[]           @relation("CreatedBy")
  activities       CrmActivity[]
  territories      Territory[]
  subscriptions    Subscription[]
  payments         Payment[]
  metrics          AgentPerformanceMetric[]
  ownerships       TerritoryOwnership[]
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  @@index([email])
  @@map("users")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum PropertyType {
  SINGLE_FAMILY
  MULTI_FAMILY
  CONDO
  TOWNHOUSE
  LAND
  COMMERCIAL
}

enum Urgency {
  IMMEDIATE
  THREE_MONTHS
  SIX_MONTHS
  EXPLORING
}

enum Temperature {
  HOT
  WARM
  COLD
}

model Lead {
  id             String        @id @default(uuid())
  firstName      String        @map("first_name")
  lastName       String        @map("last_name")
  email          String
  phone          String?
  address        String?
  city           String?
  state          String?       @default("VA")
  zipCode        String?       @map("zip_code")
  propertyType   PropertyType?
  estimatedValue Decimal?      @db.Decimal(12, 2)
  urgency        Urgency?
  score          Int           @default(0)
  temperature    Temperature   @default(COLD)
  status         LeadStatus    @default(NEW)
  source         String?       @default("manual")
  sourceUrl      String?       @map("source_url")
  notes          String?
  createdById    String        @map("created_by_id")
  createdBy      User          @relation("CreatedBy", fields: [createdById], references: [id])
  assignments    LeadAssignment[]
  activities     CrmActivity[]
  tags           LeadTag[]
  aiScores       AiLeadScore[]
  followUpSeqs   FollowUpSequence[]
  scoreHistory   LeadScoreHistory[]
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  @@index([email])
  @@index([zipCode])
  @@index([status])
  @@index([score])
  @@map("leads")
}

model LeadAssignment {
  id         String   @id @default(uuid())
  leadId     String   @map("lead_id")
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId     String   @map("user_id")
  user       User     @relation("AssignedTo", fields: [userId], references: [id])
  isActive   Boolean  @default(true) @map("is_active")
  assignedAt DateTime @default(now()) @map("assigned_at")
  notes      String?
  @@unique([leadId, userId])
  @@map("lead_assignments")
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  SMS
  STATUS_CHANGE
}

model CrmActivity {
  id          String       @id @default(uuid())
  leadId      String       @map("lead_id")
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String       @map("user_id")
  user        User         @relation(fields: [userId], references: [id])
  type        ActivityType
  subject     String?
  body        String
  outcome     String?
  scheduledAt DateTime?    @map("scheduled_at")
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  @@index([leadId])
  @@map("crm_activities")
}

model Tag {
  id    String    @id @default(uuid())
  name  String    @unique
  color String    @default("#6B7280")
  leads LeadTag[]
  @@map("tags")
}

model LeadTag {
  leadId String @map("lead_id")
  tagId  String @map("tag_id")
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  @@id([leadId, tagId])
  @@map("lead_tags")
}

// ═══════════════════════ AI MODULE ══════════════════════

model AiLeadScore {
  id               String      @id @default(uuid())
  leadId           String      @unique @map("lead_id")
  lead             Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  totalScore       Int         @map("total_score")
  temperature      Temperature
  urgencyScore     Int         @default(0) @map("urgency_score")
  budgetScore      Int         @default(0) @map("budget_score")
  intentScore      Int         @default(0) @map("intent_score")
  engagementScore  Int         @default(0) @map("engagement_score")
  creditScore      Int         @default(0) @map("credit_score")
  timelineScore    Int         @default(0) @map("timeline_score")
  summary          String?
  strengths        Json        @default("[]")
  risks            Json        @default("[]")
  recommendations  Json        @default("[]")
  callScript       String?
  objectionHandlers Json       @default("{}")
  productMatch     String?
  programMatch     String?
  closeProbability Decimal?    @db.Decimal(5, 4)
  estimatedDaysToClose Int?
  estimatedRevenue Decimal?    @db.Decimal(12, 2)
  tokensUsed       Int?
  scoreVersion     Int         @default(1)
  lastScored       DateTime    @default(now()) @map("last_scored")
  @@index([leadId])
  @@index([totalScore])
  @@map("ai_lead_scores")
}

model LeadScoreHistory {
  id          String      @id @default(uuid())
  leadId      String      @map("lead_id")
  lead        Lead        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  totalScore  Int
  temperature Temperature
  trigger     String
  delta       Int?
  snapshot    Json        @default("{}")
  createdAt   DateTime    @default(now()) @map("created_at")
  @@index([leadId])
  @@map("lead_score_history")
}

model FollowUpSequence {
  id          String   @id @default(uuid())
  leadId      String   @map("lead_id")
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel     String
  status      String   @default("active")
  steps       Json     @default("[]")
  currentStep Int      @default(0) @map("current_step")
  nextRunAt   DateTime? @map("next_run_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  @@index([leadId])
  @@map("follow_up_sequences")
}

model AiInsight {
  id          String   @id @default(uuid())
  type        String
  severity    String   @default("INFO")
  title       String
  body        String
  entityType  String?
  entityId    String?
  actionUrl   String?
  actionLabel String?
  isRead      Boolean  @default(false) @map("is_read")
  expiresAt   DateTime?
  createdAt   DateTime @default(now()) @map("created_at")
  @@map("ai_insights")
}

model AgentPerformanceMetric {
  id               String   @id @default(uuid())
  agentId          String   @map("agent_id")
  agent            User     @relation(fields: [agentId], references: [id])
  periodStart      DateTime @map("period_start")
  periodEnd        DateTime @map("period_end")
  leadsAssigned    Int      @default(0)
  leadsAccepted    Int      @default(0)
  leadsConverted   Int      @default(0)
  leadsRejected    Int      @default(0)
  avgResponseHours Decimal? @db.Decimal(5, 2)
  avgLeadScore     Decimal? @db.Decimal(5, 2)
  conversionRate   Decimal? @db.Decimal(5, 4)
  acceptanceRate   Decimal? @db.Decimal(5, 4)
  estimatedRevenue Decimal? @db.Decimal(12, 2)
  createdAt        DateTime @default(now()) @map("created_at")
  @@index([agentId])
  @@map("agent_performance_metrics")
}

// ═════════════════════ BILLING MODULE ════════════════════

model Plan {
  id            String   @id
  name          String
  displayName   String   @map("display_name")
  tier          String
  price         Decimal  @db.Decimal(10, 2)
  annualPrice   Decimal? @db.Decimal(10, 2)
  stripePriceId String?  @map("stripe_price_id")
  config        Json     @default("{}")
  isActive      Boolean  @default(true) @map("is_active")
  subscriptions Subscription[]
  @@map("plans")
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  user                 User     @relation(fields: [userId], references: [id])
  planId               String   @map("plan_id")
  plan                 Plan     @relation(fields: [planId], references: [id])
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  status               String   @default("active")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean  @default(false) @map("cancel_at_period_end")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  @@index([userId])
  @@map("subscriptions")
}

model Payment {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id])
  subscriptionId   String?  @map("subscription_id")
  stripePaymentId  String?  @unique @map("stripe_payment_id")
  amount           Decimal  @db.Decimal(10, 2)
  currency         String   @default("usd")
  status           String   @default("pending")
  refundedAmount   Decimal? @db.Decimal(10, 2)
  refundReason     String?
  invoice          Invoice?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  @@index([userId])
  @@map("payments")
}

model Invoice {
  id               String   @id @default(uuid())
  subscriptionId   String?  @map("subscription_id")
  paymentId        String?  @unique @map("payment_id")
  payment          Payment? @relation(fields: [paymentId], references: [id])
  userId           String   @map("user_id")
  stripeInvoiceId  String?  @unique @map("stripe_invoice_id")
  invoiceNumber    String   @unique @map("invoice_number")
  subtotal         Decimal  @db.Decimal(10, 2)
  tax              Decimal  @default(0) @db.Decimal(10, 2)
  total            Decimal  @db.Decimal(10, 2)
  currency         String   @default("usd")
  status           String   @default("open")
  dueDate          DateTime? @map("due_date")
  paidAt           DateTime? @map("paid_at")
  lineItems        Json     @default("[]")
  billingDetails   Json     @default("{}")
  invoicePdfUrl    String?
  periodStart      DateTime? @map("period_start")
  periodEnd        DateTime? @map("period_end")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  @@index([userId])
  @@map("invoices")
}

model UsageRecord {
  id             String   @id @default(uuid())
  subscriptionId String   @map("subscription_id")
  userId         String   @map("user_id")
  metric         String
  quantity       Int
  periodStart    DateTime @map("period_start")
  periodEnd      DateTime @map("period_end")
  createdAt      DateTime @default(now()) @map("created_at")
  @@index([subscriptionId])
  @@map("usage_records")
}

// ════════════════════ TERRITORY MODULE ═══════════════════

model Territory {
  id          String   @id @default(uuid())
  zipCode     String   @map("zip_code")
  city        String
  county      String?
  state       String   @default("VA")
  stateCode   String   @map("state_code")
  displayName String   @map("display_name")
  type        String   @default("EXCLUSIVE")
  status      String   @default("ACTIVE")
  userId      String?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id])
  isActive    Boolean  @default(true) @map("is_active")
  monthlyPrice Decimal? @db.Decimal(10, 2)
  leadsPerMonth Int?
  priority    Int      @default(0)
  assignedAt  DateTime @default(now()) @map("assigned_at")
  assignments TerritoryAssignment[]
  notifications TerritoryNotification[]
  ownerships  TerritoryOwnership[]
  @@unique([zipCode, userId])
  @@map("territories")
}

model TerritoryOwnership {
  id            String   @id @default(uuid())
  territoryId   String   @map("territory_id")
  territory     Territory @relation(fields: [territoryId], references: [id])
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id])
  isActive      Boolean  @default(true) @map("is_active")
  leadsReceived Int      @default(0)
  startDate     DateTime @default(now()) @map("start_date")
  endDate       DateTime? @map("end_date")
  @@unique([territoryId, userId])
  @@map("territory_ownerships")
}

model TerritoryAssignment {
  id          String    @id @default(uuid())
  territoryId String    @map("territory_id")
  territory   Territory @relation(fields: [territoryId], references: [id])
  leadId      String    @map("lead_id")
  assignedAt  DateTime  @default(now()) @map("assigned_at")
  @@map("territory_assignments")
}

model TerritoryNotification {
  id          String    @id @default(uuid())
  territoryId String    @map("territory_id")
  territory   Territory @relation(fields: [territoryId], references: [id])
  type        String
  message     String
  isRead      Boolean   @default(false) @map("is_read")
  createdAt   DateTime  @default(now()) @map("created_at")
  @@map("territory_notifications")
}

// ══════════════════════ SEO MODULE ═══════════════════════

enum ServiceType {
  SELL_HOUSE_FAST
  CASH_OFFER
  FORECLOSURE
  PROBATE
  DIVORCE_SALE
  FIRST_TIME_BUYER
  REFINANCE
  INVESTMENT_PROPERTY
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model SeoTemplate {
  id                      String      @id @default(uuid())
  name                    String
  slug                    String      @unique
  serviceType             ServiceType
  description             String?
  titleTemplate           String
  metaDescTemplate        String
  h1Template              String
  heroHeadlineTemplate    String
  heroSubheadlineTemplate String
  bodyTemplate            String      @db.Text
  faqTemplate             Json        @default("[]")
  ctaText                 String      @default("Get My Cash Offer")
  ctaSubtext              String?
  aiEnabled               Boolean     @default(true)
  aiPromptAdditions       String?
  isActive                Boolean     @default(true)
  pages                   SeoPage[]
  createdAt               DateTime    @default(now()) @map("created_at")
  updatedAt               DateTime    @updatedAt @map("updated_at")
  @@index([serviceType])
  @@map("seo_templates")
}

model Location {
  id              String   @id @default(uuid())
  zipCode         String   @unique @map("zip_code")
  city            String
  county          String?
  state           String
  stateCode       String   @map("state_code")
  latitude        Decimal? @db.Decimal(9, 6)
  longitude       Decimal? @db.Decimal(9, 6)
  population      Int?
  medianIncome    Int?     @map("median_income")
  medianHomeValue Int?     @map("median_home_value")
  isActive        Boolean  @default(true) @map("is_active")
  priority        Int      @default(0)
  pages           SeoPage[]
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  @@index([stateCode])
  @@index([isActive, priority])
  @@map("locations")
}

model SeoPage {
  id          String      @id @default(uuid())
  templateId  String      @map("template_id")
  template    SeoTemplate @relation(fields: [templateId], references: [id])
  locationId  String      @map("location_id")
  location    Location    @relation(fields: [locationId], references: [id])
  fullPath    String      @unique @map("full_path")
  title       String
  metaDesc    String      @map("meta_desc")
  content     String      @db.Text
  status      PageStatus  @default(DRAFT)
  viewCount   Int         @default(0)
  leads       SeoPageLead[]
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  @@index([templateId])
  @@index([locationId])
  @@index([status])
  @@map("seo_pages")
}

model SeoPageLead {
  id        String   @id @default(uuid())
  pageId    String   @map("page_id")
  page      SeoPage  @relation(fields: [pageId], references: [id], onDelete: Cascade)
  name      String
  email     String
  phone     String?
  message   String?
  createdAt DateTime @default(now()) @map("created_at")
  @@map("seo_page_leads")
}

model SeoJob {
  id        String   @id @default(uuid())
  status    String   @default("pending")
  total     Int      @default(0)
  completed Int      @default(0)
  failed    Int      @default(0)
  config    Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  @@map("seo_jobs")
}

// ══════════════════ MARKETPLACE MODULE ══════════════════

enum MarketplaceListingType {
  TERRITORY
  LEAD_PACKAGE
  CUSTOM
}

enum MarketplaceListingStatus {
  ACTIVE
  INACTIVE
  SOLD
}

model MarketplaceListing {
  id             String                   @id @default(uuid())
  type           MarketplaceListingType
  status         MarketplaceListingStatus @default(ACTIVE)
  sellerId       String?                  @map("seller_id")
  territoryId    String?                  @map("territory_id")
  title          String
  description    String?
  highlights     Json                     @default("[]")
  price          Decimal                  @db.Decimal(10, 2)
  isRecurring    Boolean                  @default(false)
  recurringPrice Decimal?                 @db.Decimal(10, 2)
  leadsPerMonth  Int?
  medianValue    String?
  viewCount      Int                      @default(0)
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  @@index([type])
  @@index([status])
  @@map("marketplace_listings")
}
