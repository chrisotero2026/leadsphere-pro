# ════════════════════════════════════════════════
# LeadSphere Pro — VARIABLES DE ENTORNO
# Copia este archivo como .env y llena los valores
# ════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────
# Para desarrollo local con Docker:
DATABASE_URL="postgresql://postgres:leadsphere123@localhost:5432/leadsphere"
# Para producción (Railway, Neon, Supabase):
# DATABASE_URL="postgresql://user:password@host:5432/leadsphere"

# ── Redis ─────────────────────────────────────────
# Para desarrollo local con Docker:
REDIS_URL="redis://localhost:6379"
# Para producción (Upstash):
# REDIS_URL="rediss://default:password@host:6379"

# ── JWT ───────────────────────────────────────────
JWT_SECRET="cambia-esto-por-una-cadena-aleatoria-de-64-caracteres-minimo"
JWT_EXPIRES_IN="7d"

# ── Servidor ──────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ═══════════════════════════════════════════════════
# SERVICIOS EXTERNOS — Agrega tus keys aquí
# ═══════════════════════════════════════════════════

# ── OpenAI (AI Lead Scoring) ──────────────────────
# Obtén tu key en: https://platform.openai.com/api-keys
# Costo estimado: ~$0.01 por lead scored
OPENAI_API_KEY=""

# ── Anthropic Claude (alternativa a OpenAI) ───────
# Obtén tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Modelo a usar (gpt-4o-mini es el más barato)
AI_MODEL="gpt-4o-mini"
# Pon "true" si no tienes key — usará scoring por reglas
AI_DISABLE=false

# ── Twilio (SMS + Llamadas) ───────────────────────
# Trial gratis en: https://www.twilio.com/try-twilio
# El trial da $15 de crédito sin tarjeta
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""
# Ejemplo: TWILIO_PHONE_NUMBER="+12025551234"
TWILIO_MESSAGING_SERVICE_SID=""

# ── ElevenLabs (Voz AI) ───────────────────────────
# Gratis hasta 10,000 chars/mes: https://elevenlabs.io
ELEVENLABS_API_KEY=""
# ID de voz — "Rachel" es la default
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"

# ── Stripe (Pagos) ────────────────────────────────
# Cuenta gratis: https://dashboard.stripe.com/register
# USA sk_test_... para pruebas — NO cobra dinero real
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price IDs — créalos en el dashboard de Stripe
STRIPE_PRICE_BASIC_MONTHLY=""
STRIPE_PRICE_PROFESSIONAL_MONTHLY=""
STRIPE_PRICE_ENTERPRISE_MONTHLY=""

# ── Resend (Email) ────────────────────────────────
# Gratis 3,000 emails/mes: https://resend.com
RESEND_API_KEY=""
FROM_EMAIL="noreply@tudominio.com"
FROM_NAME="LeadSphere Pro"

# ── URLs de la app ────────────────────────────────
APP_URL="http://localhost:3000"
API_URL="http://localhost:3001"